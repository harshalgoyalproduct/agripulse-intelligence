# Database
DATABASE_URL=postgresql+asyncpg://agripulse:agripulse@localhost:5432/agripulse

# External APIs
NASA_POWER_BASE_URL=https://power.larc.nasa.gov/api/temporal/daily/point
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1
SENTINEL_CDSE_BASE_URL=https://opbs.sentinel-hub.com
SMAP_BASE_URL=https://n5eil01u.eosdis.nasa.gov
NOAA_VHI_BASE_URL=https://www.star.nesdis.noaa.gov/smcd/emb/vci/VH

# Security
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# App Settings
DEBUG=False
ENVIRONMENT=development
APP_NAME=AgriPulse Intelligence
API_PREFIX=/api/v1

# CORS
ALLOWED_ORIGINS=http://localhost,http://localhost:3000,http://localhost:8000
