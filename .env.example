# AgriPulse Intelligence — Environment Configuration Template
# Copy this file to .env and fill in your actual values

# ============================================
# ENVIRONMENT CONFIGURATION
# ============================================
ENVIRONMENT=development
DEBUG=false

# ============================================
# DATABASE CONFIGURATION
# ============================================
POSTGRES_USER=agripulse
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=agripulse
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://agripulse:your_secure_password_here@localhost:5432/agripulse

# TimescaleDB extension (automatic in our docker-compose)
TIMESCALEDB_ENABLED=true

# ============================================
# REDIS CACHE CONFIGURATION
# ============================================
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# ============================================
# APPLICATION SECURITY
# ============================================
SECRET_KEY=your_random_32_character_secret_key_here_change_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# ============================================
# CORS & FRONTEND CONFIGURATION
# ============================================
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ============================================
# EXTERNAL API CONFIGURATION — NASA POWER
# ============================================
NASA_POWER_BASE_URL=https://power.larc.nasa.gov
NASA_POWER_API_VERSION=v2
NASA_POWER_TIMEOUT=30
# Note: NASA POWER does not require authentication

# ============================================
# EXTERNAL API CONFIGURATION — Open-Meteo (Backup)
# ============================================
OPEN_METEO_BASE_URL=https://api.open-meteo.com
OPEN_METEO_TIMEOUT=15

# ============================================
# EXTERNAL API CONFIGURATION — eNAM Mandi Prices
# ============================================
ENAM_BASE_URL=https://api.enam.gov.in
ENAM_API_KEY=your_enam_api_key_here
ENAM_TIMEOUT=30

# ============================================
# EXTERNAL API CONFIGURATION — NOAA
# ============================================
NOAA_BASE_URL=https://api.weather.gov
NOAA_TIMEOUT=30

# ============================================
# DATA INGESTION SCHEDULES
# ============================================
# All intervals in hours
SATELLITE_UPDATE_INTERVAL_HOURS=6
WEATHER_UPDATE_INTERVAL_HOURS=3
MANDI_UPDATE_INTERVAL_HOURS=24
FORECAST_UPDATE_INTERVAL_HOURS=6

# ============================================
# LOGGING CONFIGURATION
# ============================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# Possible values: INFO, DEBUG, WARNING, ERROR, CRITICAL
# json format recommended for production (parseable by ELK/DataDog)

# ============================================
# MONITORING & OBSERVABILITY
# ============================================
# Datadog Agent (optional)
DATADOG_ENABLED=false
DATADOG_API_KEY=
DATADOG_APP_KEY=
DATADOG_SITE=datadoghq.com

# Sentry Error Tracking (optional)
SENTRY_ENABLED=false
SENTRY_DSN=

# ============================================
# EMAIL CONFIGURATION (Future: User notifications)
# ============================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_specific_password
SMTP_FROM_EMAIL=noreply@agripulse.ai

# ============================================
# SMS GATEWAY CONFIGURATION (Future: Farmer alerts)
# ============================================
SMS_PROVIDER=twilio  # twilio, exotel, nexmo
SMS_API_KEY=
SMS_API_SECRET=
SMS_FROM_NUMBER=+91XXXXXXXXXX

# ============================================
# MACHINE LEARNING MODEL CONFIGURATION
# ============================================
MODEL_PATH=/app/models/demand_forecast_v1.pkl
MODEL_VERSION=1.0
ENABLE_MODEL_AUTO_UPDATE=true
MODEL_RETRAINING_INTERVAL_DAYS=7

# ============================================
# GEOGRAPHIC & DOMAIN CONFIGURATION
# ============================================
PILOT_REGION=vidarbha
PILOT_STATES=maharashtra
PILOT_DISTRICTS=akola,amravati,buldhana,washim,yavatmal,nagpur,wardha

# Coordinates for data fetching (bounding box)
GEO_BOUNDING_BOX_MIN_LAT=16.0
GEO_BOUNDING_BOX_MAX_LAT=21.0
GEO_BOUNDING_BOX_MIN_LON=74.0
GEO_BOUNDING_BOX_MAX_LON=79.0

# ============================================
# FEATURE FLAGS
# ============================================
FEATURE_SATELLITE_NDVI=true
FEATURE_MANDI_PRICES=true
FEATURE_WEATHER_FORECAST=true
FEATURE_PEST_ALERTS=false          # Phase 2
FEATURE_SOIL_MOISTURE=false        # Phase 4
FEATURE_FARMER_SMS=false           # Future
FEATURE_YIELD_FORECASTS=false      # Future

# ============================================
# API RATE LIMITING
# ============================================
RATE_LIMIT_FREE_TIER_CALLS_PER_HOUR=100
RATE_LIMIT_PAID_TIER_CALLS_PER_HOUR=10000
RATE_LIMIT_ADMIN_CALLS_PER_HOUR=1000000

# ============================================
# BACKUP & DISASTER RECOVERY
# ============================================
BACKUP_ENABLED=true
BACKUP_FREQUENCY=daily
BACKUP_RETENTION_DAYS=30
AWS_S3_BACKUP_BUCKET=agripulse-backups

# ============================================
# AWS CONFIGURATION (Optional: For S3, RDS, etc.)
# ============================================
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=agripulse-production

# ============================================
# NEXT.JS FRONTEND CONFIGURATION
# ============================================
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=AgriPulse Intelligence
NEXT_PUBLIC_APP_VERSION=0.1.0
NEXT_PUBLIC_SENTRY_ENABLED=false

# ============================================
# DEVELOPMENT & TESTING
# ============================================
# Set to 'true' only in development/testing
ALLOW_TEST_DATA_SEED=true
SKIP_EMAIL_VERIFICATION=false
ALLOW_DEMO_ACCOUNTS=false
