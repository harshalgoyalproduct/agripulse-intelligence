{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm ci",
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "${BACKEND_URL}/api/v1/:path*"
    }
  ],
  "env": {
    "NEXT_PUBLIC_API_BASE_URL": "${BACKEND_URL}"
  }
}
